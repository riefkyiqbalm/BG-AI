{
  "name": "my-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean:dist": "rm -rf dist",
    "build:css": "npx @tailwindcss/cli -i ./styles/style-main.css -o ./dist/styles/style-main.css --minify",
    "copy:html": "cpx \"./*.html\" ./dist",
    "copy:js": "cpx \"./script/script-main.js\" ./dist/script",
    "copy:assets": "cpx \"./assets/**/*\" dist/assets",
    "build": "npm run clean:dist && npm run build:css && npm run copy:html && npm run copy:js",
    "start": "http-server ./dist", 
    "deploy:s3": "aws s3 sync ./dist s3://balteng.com --delete --acl public-read --cache-control max-age=31536000,public"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "gh-pages": "^6.1.1",
    "http-server": "^14.1.1",
    "tailwindcss": "4.x.x",
    "@tailwindcss/cli": "4.x.x",
    "postcss": "^8.x.x",
    "autoprefixer": "^10.x.x",
    "cpx": "^1.5.0" 
  }
}